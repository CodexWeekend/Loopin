generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  trips         TripRecord[]
  presences     PresenceRecord[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  firstName   String?
  lastName    String?
  avatarUrl   String?
  travelStyle String?
  interests   String  @default("")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TripRecord {
  id                  String          @id @default(cuid())
  userId              String
  destinationCity     String
  destinationCountry  String?
  startDate           DateTime
  endDate             DateTime
  partySize           Int
  budget              String
  pace                String
  hiddenGemPreference String
  interests           String
  isPublic            Boolean         @default(false)
  status              String          @default("draft")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  days                TripDayRecord[]
  savedPlaces         SavedPlaceRecord[]
}

model TripDayRecord {
  id            String           @id @default(cuid())
  tripId        String
  dayNumber     Int
  date          DateTime
  estimatedCost Float           @default(0)
  notes         String?
  trip          TripRecord      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stops         TripStopRecord[]
}

model TripStopRecord {
  id            String        @id @default(cuid())
  dayId         String
  placeId       String
  placeName     String
  startTime     String
  endTime       String?
  orderIndex    Int
  travelMode    String?
  travelMinutes Int?
  notes         String?
  day           TripDayRecord @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model SavedPlaceRecord {
  id        String     @id @default(cuid())
  tripId    String
  placeId   String
  createdAt DateTime   @default(now())
  trip      TripRecord @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PresenceRecord {
  id              String   @id @default(cuid())
  userId          String
  citySlug        String
  visibleFrom     DateTime
  visibleTo       DateTime
  showCityPresence Boolean @default(true)
  showPlacePresence Boolean @default(false)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  intents         IntentRecord[]
}

model IntentRecord {
  id          String         @id @default(cuid())
  presenceId  String
  title       String
  description String
  category    String
  createdAt   DateTime       @default(now())
  presence    PresenceRecord @relation(fields: [presenceId], references: [id], onDelete: Cascade)
}
