{
  "name": "loopin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "dev:api": "corepack pnpm --filter @loopin/api dev",
    "dev:mobile": "corepack pnpm --filter @loopin/mobile dev",
    "dev:web": "corepack pnpm --filter @loopin/web dev",
    "lint": "corepack pnpm lint:root && corepack pnpm -r --if-present lint",
    "lint:root": "eslint tests vitest.config.ts --ext .ts",
    "test": "vitest run",
    "test:ci": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && corepack pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.2",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}
