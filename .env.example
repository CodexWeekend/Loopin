# Loopin environment contract
# Copy the values you need into untracked local .env files.
# Never commit real secrets.

# Shared services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loopin
REDIS_URL=redis://localhost:6379
AUTH_SECRET=replace-me

# AI and discovery providers
OPENAI_API_KEY=
EXA_API_KEY=
FAL_KEY=

# Maps
MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Frontend to API URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
